OPENAI_API_KEY=sk-your-provider-key
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
TOKENWATCH_ADMIN_KEY=change-this-long-random-secret
# true for a public portfolio demo; false for a private production instance
TOKENWATCH_DEMO_MODE=true
TOKENWATCH_SEED_DEMO=true
CORS_ALLOWED_ORIGINS=https://token-tracker.dev,https://www.token-tracker.dev,https://api.token-tracker.dev
DATABASE_URL=sqlite+aiosqlite:////app/data/tokenwatch.db
BUDGET_MODE=observe
