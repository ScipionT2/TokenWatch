# OpenAI API Key (for proxy mode — routes requests through Sentinel)
OPENAI_API_KEY=sk-your-key-here

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Database (SQLite for dev, swap for Postgres in prod)
DATABASE_URL=sqlite+aiosqlite:///./sentinel.db

# Cost alerts
ALERT_DAILY_BUDGET=50.00
ALERT_PER_REQUEST_MAX=5.00
ALERT_WEBHOOK_URL=

# Token optimization
MAX_PROMPT_TOKENS=8000
ENABLE_PROMPT_COMPRESSION=true
ENABLE_CACHE_DEDUP=true
CACHE_TTL_SECONDS=3600

# Rate limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_TPM=100000
