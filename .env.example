# OpenAI API Key (for proxy mode — routes requests through Token-Tracker)
OPENAI_API_KEY=sk-your-key-here

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
# Optional. When set, sensitive admin/control-plane endpoints require X-Token-Tracker-Admin-Key.
TOKENWATCH_ADMIN_KEY=
# Optional public read-only HTML mode for hosted demos. Admin APIs still require TOKENWATCH_ADMIN_KEY.
TOKENWATCH_DEMO_MODE=false
# Seed realistic demo data on startup if request/project storage is empty.
TOKENWATCH_SEED_DEMO=false
# Comma-separated origins. Keep * for local dev; use explicit domains in production.
CORS_ALLOWED_ORIGINS=*

# Database (SQLite for dev, swap for Postgres in prod)
DATABASE_URL=sqlite+aiosqlite:///./tokenwatch.db

# Cost alerts / budget controls
ALERT_DAILY_BUDGET=50.00
ALERT_PER_REQUEST_MAX=5.00
ALERT_WEBHOOK_URL=
BUDGET_MODE=observe

# Token optimization
MAX_PROMPT_TOKENS=8000
ENABLE_PROMPT_COMPRESSION=true
ENABLE_CACHE_DEDUP=true
CACHE_TTL_SECONDS=3600

# Rate limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_TPM=100000
